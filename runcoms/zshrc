# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...
if [[ $(uname) == 'Darwin' ]]; then
  test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

  # Add /opt/homebrew/bin to path
  export PATH=/opt/homebrew/bin:$PATH
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
if [[ "$TERM" == "linux" ]]; then
  PROMPT='%F{green}%n@%m%f %F{blue}%~%f %# '
else
  [[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
fi
# Add nodebrew to path
export PATH=$HOME/.nodebrew/current/bin:$PATH

alias "?s"="gh copilot suggest"
alias "?e"="gh copilot explain"

# Add fzf(fuzzy finder) to path
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

fpath=(~/.zsh/completion $fpath)
autoload -Uz compinit && compinit -i

alias fzfv='fzf --preview "bat  --color=always --style=header,grid --line-range :100\
 {}"'

# fzf history
function fzf-select-history() {
    BUFFER=$(~/.zsh/fzf-history.sh | fzf --query "$LBUFFER" --scheme=default \
        --bind "ctrl-d:execute-silent(~/.zsh/fzf-history.sh delete {})+reload(~/.zsh/fzf-history.sh)")
    CURSOR=$#BUFFER
    zle reset-prompt
}
zle -N fzf-select-history
bindkey '^r' fzf-select-history

# cdr自体の設定
if [[ -n $(echo ${^fpath}/chpwd_recent_dirs(N)) && -n $(echo ${^fpath}/cdr(N)) ]]; then
    autoload -Uz chpwd_recent_dirs cdr add-zsh-hook
    add-zsh-hook chpwd chpwd_recent_dirs
    zstyle ':completion:*' recent-dirs-insert both
    zstyle ':chpwd:*' recent-dirs-default true
    zstyle ':chpwd:*' recent-dirs-max 1000
fi

# fzf cdr
function fzf-cdr() {
    local selected_dir=$(cdr -l | awk '{ print $2 }' | fzf --reverse)
    if [ -n "$selected_dir" ]; then
        BUFFER="cd ${selected_dir}"
        zle accept-line
    fi
    zle clear-screen
}
zle -N fzf-cdr
setopt noflowcontrol
setopt HIST_IGNORE_ALL_DUPS
bindkey '^q' fzf-cdr

# sshを実行したあとにechoを実行する関数を定義
function ssh() {
  echo -e "\033]50;SetProfile=$1\a"
  command ssh "$@"
  echo -e "\033]50;SetProfile=Default\a"
}

# deno
# export DENO_INSTALL="${HOME}/.deno"
# export PATH="$DENO_INSTALL/bin:$PATH"

# .zshrc実行後に行いたいカスタマイズ
if [[ -r "${HOME}/.zshrc_after" ]]; then
  source "${HOME}/.zshrc_after"
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

nvm use default >/dev/null 2>&1

# .nvmrc があれば自動で nvm use する
autoload -U add-zsh-hook
load-nvmrc() {
  local nvmrc_path="$(nvm_find_nvmrc)"
  if [ -n "$nvmrc_path" ]; then
    local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")
    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
      nvm use
    fi
  fi
}
add-zsh-hook chpwd load-nvmrc
load-nvmrc

# ssh-agentの起動
# 既に `ssh-agent` が動いているか確認し、なければ起動する
if ! pgrep -x "ssh-agent" > /dev/null; then
    eval "$(ssh-agent -s)"
fi
export SSH_AUTH_SOCK=$(find /tmp/ -type s -name 'agent.*' 2>/dev/null | head -n 1)
# Pyenv設定 (company-regulations)
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv >/dev/null 2>&1; then
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
fi

if [[ "${TERM_PROGRAM:-}" == "vscode" ]] && command -v code >/dev/null 2>&1; then
    VSCODE_ZSH_INTEGRATION="$(code --locate-shell-integration-path zsh 2>/dev/null || true)"
    if [[ -n "$VSCODE_ZSH_INTEGRATION" && -r "$VSCODE_ZSH_INTEGRATION" ]]; then
        source "$VSCODE_ZSH_INTEGRATION"
    fi
fi

# Go
export PATH=/usr/local/go/bin:$HOME/go/bin:$PATH

# Claude Code (native binary)
export PATH="$HOME/.local/bin:$PATH"
